def video_arka_plan(video_path):
    video_html = f"""
    <style>
    .stApp {{
        background: none;
    }}
    .video-container {{
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        object-fit: cover;
    }}
    </style>
    <video autoplay muted loop playsinline class="video-container">
        <source src="{video_path}" type="video/mp4">
    </video>
    """
    components.html(video_html)
